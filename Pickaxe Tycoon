task.spawn(function()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Workspace = game:GetService("Workspace")
    local player = Players.LocalPlayer
    local plots = workspace.Plots
    local character = player.Character or player.CharacterAdded:Wait()

    -- Top-level variable visible to all blocks
    local myPlot = nil 

    local function getNearestButton()
        local player = Players.LocalPlayer
        if not player or not player.Character then return nil end
        local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return nil end

        local closestButton = nil
        local shortestDistance = math.huge

        for _, object in ipairs(Workspace:GetDescendants()) do
            if object:IsA("MeshPart") and object.Name == "Button" then
                local distance = (rootPart.Position - object.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestButton = object
                end
            end
        end

        return closestButton, shortestDistance
    end

    -- Run function once at startup to assign your plot
    local nearestButton, dist = getNearestButton()
    if nearestButton then
        print("The nearest button is: " .. nearestButton:GetFullName() .. " at " .. tostring(math.round(dist)) .. " studs away.")
        myPlot = nearestButton.Parent.Parent.Parent
        print("Successfully set myPlot to: " .. myPlot.Name)
    else
        print("No MeshPart named 'Button' was found in the workspace at script launch.")
    end

    -- TOGGLE STATES
    local autoLootEnabled = false
    local scriptRunning = true
    local autoCollectEnabled = false
    local autoDepositEnabled = false
    local autoBuyEnabled = false        -- Changed from autoBuy1
    local buyAmount = 1                 -- Holds current selection: 1, 5, 25, or 100
    local autoMergeEnabled = false      
    local autoEverythingEnabled = false

    -- UI Setup & Duplicate Clean
    local targetParent = game:GetService("CoreGui") or player:WaitForChild("PlayerGui")
    if targetParent:FindFirstChild("SimpleMenu") then targetParent.SimpleMenu:Destroy() end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SimpleMenu"
    ScreenGui.Parent = targetParent

    -- Main Window (Increased height to 555 to fit the new selection row)
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0, 200, 0, 555)
    MainFrame.Position = UDim2.new(0.5, -100, 0.3, -277)
    MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    MainFrame.Draggable = true
    MainFrame.Active = true
    MainFrame.Parent = ScreenGui

    -- Close / Unload Button
    local UnloadButton = Instance.new("TextButton")
    UnloadButton.Size = UDim2.new(0, 25, 0, 25)
    UnloadButton.Position = UDim2.new(1, -30, 0, 5)
    UnloadButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    UnloadButton.Text = "X"
    UnloadButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    UnloadButton.Parent = MainFrame

    -- BUTTON: Buy 100
    local SimpleButton = Instance.new("TextButton")
    SimpleButton.Size = UDim2.new(0, 180, 0, 40)
    SimpleButton.Position = UDim2.new(0, 10, 0, 40)
    SimpleButton.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    SimpleButton.Text = "Buy 100"
    SimpleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    SimpleButton.Parent = MainFrame

    SimpleButton.MouseButton1Click:Connect(function()
        task.spawn(function()
            if myPlot and scriptRunning then
                local buttonsFolder = myPlot:FindFirstChild("Buttons")
                local buy100Folder = buttonsFolder and buttonsFolder:FindFirstChild("ButtonBuy100")
                local targetButton = buy100Folder and buy100Folder:FindFirstChild("Button")
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                
                if targetButton and rootPart then
                    local touchInterest = targetButton:FindFirstChildOfClass("TouchTransmitter") or targetButton:FindFirstChild("TouchInterest")
                    if touchInterest then
                        firetouchinterest(targetButton, rootPart, 0)
                        task.wait()
                        firetouchinterest(targetButton, rootPart, 1)
                    end
                end
            end
        end)
