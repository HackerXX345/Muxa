    local function getNearestButton()
        local player = Players.LocalPlayer
        if not player or not player.Character then return nil end
        local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return nil end

        local closestButton = nil
        local shortestDistance = math.huge

        for _, object in ipairs(Workspace:GetDescendants()) do
            if object:IsA("MeshPart") and object.Name == "Button" then
                local distance = (rootPart.Position - object.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestButton = object
                end
            end
        end

        return closestButton, shortestDistance
    end

